<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <solid android:color="@color/option_surface_selected" />
            <stroke
                android:width="2dp"
                android:color="@color/option_stroke_selected" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <solid android:color="@color/option_surface" />
            <stroke
                android:width="1dp"
                android:color="@color/option_stroke" />
        </shape>
    </item>
</selector>

